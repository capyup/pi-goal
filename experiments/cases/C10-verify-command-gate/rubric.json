    "desc": "create_goal called with sisyphus=true.",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": ".sisyphus == true"
  },
  {
    "id": "objective-has-3-steps",
    "desc": "Objective must preserve all requested target files so strict execution is possible.",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": "(.objective | test(\"a\\\\.txt|alpha\\\\.txt\")) and (.objective | test(\"b\\\\.txt|beta\\\\.txt\")) and (.objective | test(\"c\\\\.txt|gamma\\\\.txt\"))"
  },
  {
    "id": "alpha-txt-content",
    "desc": "alpha.txt must contain exactly 'hello'.",
    "kind": "sandbox-file-contains",
    "path": "alpha.txt",
    "pattern": "^hello$"
  },
  {
    "id": "beta-txt-content",
    "desc": "beta.txt must contain exactly 'world'.",
    "kind": "sandbox-file-contains",
    "path": "beta.txt",
    "pattern": "^world$"
  },
  {
    "id": "gamma-txt-content",
    "desc": "gamma.txt must contain exactly 'hello world'.",
    "kind": "sandbox-file-contains",
    "path": "gamma.txt",
    "pattern": "^hello world$"
  },
  {
    "id": "verification-bash-used",
    "desc": "Agent should use shell verification commands for the requested file contents before completion.",
    "kind": "tool-call-count",
    "tool": "bash",
    "op": "ge",
    "count": 3
  },
  {
    "id": "update-goal-complete",
    "desc": "Agent should call update_goal=complete after all requested outputs are verified.",
    "kind": "tool-args-jq",
    "tool": "update_goal",
    "jq": ".status == \"complete\""
  }
