[
  {
    "id": "create-goal-sisyphus",
    "desc": "create_goal called with sisyphus=true.",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": ".sisyphus == true"
  },
  {
    "id": "objective-has-3-steps",
    "desc": "Objective must contain three numbered steps (1., 2., 3.).",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": "(.objective | test(\"\\\\b1\\\\.\")) and (.objective | test(\"\\\\b2\\\\.\")) and (.objective | test(\"\\\\b3\\\\.\"))"
  },
  {
    "id": "a-txt-exists",
    "desc": "Step 1 outcome: a.txt should exist with content 'a'.",
    "kind": "sandbox-file-contains",
    "path": "a.txt",
    "pattern": "^a$"
  },
  {
    "id": "b-txt-exists",
    "desc": "Step 2 outcome: b.txt should exist with content 'b'.",
    "kind": "sandbox-file-contains",
    "path": "b.txt",
    "pattern": "^b$"
  },
  {
    "id": "c-txt-exists",
    "desc": "Step 3 outcome: c.txt should exist with content 'c'.",
    "kind": "sandbox-file-contains",
    "path": "c.txt",
    "pattern": "^c$"
  },
  {
    "id": "step-complete-called-3-times",
    "desc": "step_complete must be called once per step (3 calls) before update_goal=complete is accepted.",
    "kind": "tool-call-count",
    "tool": "step_complete",
    "op": "ge",
    "count": 3
  },
  {
    "id": "update-goal-complete",
    "desc": "Agent should call update_goal=complete after all 3 steps are verified and step_complete'd.",
    "kind": "tool-args-jq",
    "tool": "update_goal",
    "jq": ".status == \"complete\""
  },
  {
    "id": "step-complete-uses-verifycommand",
    "desc": "At least 2 of the 3 step_complete calls should pass verifyCommand (user explicitly asked).",
    "kind": "tool-call-count",
    "tool": "step_complete",
    "argsJq": "(.verifyCommand // \"\") | length > 0",
    "op": "ge",
    "count": 2
  }
]
