[
  {
    "id": "create-goal-sisyphus",
    "desc": "create_goal called with sisyphus=true.",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": ".sisyphus == true"
  },
  {
    "id": "objective-has-3-steps",
    "desc": "Objective must preserve all requested target files so strict execution is possible.",
    "kind": "tool-args-jq",
    "tool": "propose_goal_draft",
    "jq": "(.objective | test(\"a\\\\.txt|alpha\\\\.txt\")) and (.objective | test(\"b\\\\.txt|beta\\\\.txt\")) and (.objective | test(\"c\\\\.txt|gamma\\\\.txt\"))"
  },
  {
    "id": "a-txt-exists",
    "desc": "Step 1 outcome: a.txt should exist with content 'a'.",
    "kind": "sandbox-file-contains",
    "path": "a.txt",
    "pattern": "^a$"
  },
  {
    "id": "b-txt-exists",
    "desc": "Step 2 outcome: b.txt should exist with content 'b'.",
    "kind": "sandbox-file-contains",
    "path": "b.txt",
    "pattern": "^b$"
  },
  {
    "id": "c-txt-exists",
    "desc": "Step 3 outcome: c.txt should exist with content 'c'.",
    "kind": "sandbox-file-contains",
    "path": "c.txt",
    "pattern": "^c$"
  },
  {
    "id": "no-read-pi-docs",
    "desc": "Agent should not waste a continuation reading pi package docs instead of using the available lifecycle tool.",
    "kind": "tool-args-jq-none",
    "tool": "read",
    "jq": ".path | test(\"node_modules|@earendil-works\")"
  },
  {
    "id": "update-goal-complete",
    "desc": "Agent should call update_goal=complete after all 3 steps are verified .",
    "kind": "tool-args-jq",
    "tool": "update_goal",
    "jq": ".status == \"complete\""
  }
]
